{
  "enabledPlugins": {
    "claude-mem@thedotmack": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/combined-guard.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/secrets-guard.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
